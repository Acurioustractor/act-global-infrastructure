  "ownership_rules": {
    "canonical_knowledge": {
      "owner_id": "act-wiki",
      "mirror_targets": [
        "act-regenerative-studio",
        "command-center"
      ],
      "rule": "Meaning is authored in the wiki first, then regenerated downstream."
    },
    "runtime_state": {
      "owner_id": "act-supabase-ledger",
      "mirror_targets": [
        "empathy-ledger",
        "command-center",
        "act-regenerative-studio"
      ],
      "rule": "Permissions, IDs, sync state, and release state must be led by Supabase-backed runtime state."
    },
    "public_hub": {
      "owner_id": "act-regenerative-studio",
      "rule": "The umbrella public front door lives in ACT Regenerative Studio."
    },
    "story_and_media_packets": {
      "owner_id": "empathy-ledger",
      "rule": "Approved source packets originate in the story/media layer, then syndicate outward."
    },
    "public_work_copy": {
      "default_owner_id": "act-regenerative-studio",
      "exceptions": {
        "empathy-ledger": "empathy-ledger"
      },
      "human_decision_required": true,
      "rule": "Cross-surface works should default to the hub unless the work is structurally part of a spoke's native product or community interface."
    }
