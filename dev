#!/bin/bash
# ACT Ecosystem - Dev Server & Cron Control
# Usage: ./dev [start|stop|restart|status|logs|cron|stop-cron|all]

cd /Users/benknight/Code/act-global-infrastructure

case "$1" in
  start)
    pm2 start ecosystem.config.cjs --only "act-frontend"
    sleep 3
    pm2 status
    echo ""
    echo "Command Center: http://localhost:3002"
    ;;
  stop)
    pm2 stop act-frontend 2>/dev/null
    ;;
  restart)
    pm2 restart act-frontend 2>/dev/null
    ;;
  cron)
    # Start all cron scripts (everything except act-frontend)
    pm2 start ecosystem.config.cjs
    pm2 stop act-frontend 2>/dev/null
    sleep 2
    pm2 status
    echo ""
    echo "All cron scripts started. Logs in /tmp/<name>-{out,error}.log"
    ;;
  stop-cron)
    # Stop everything except act-frontend
    pm2 list --no-color | grep -v act-frontend | grep -oP '│\s+\K[\w-]+(?=\s+│)' | while read name; do
      pm2 stop "$name" 2>/dev/null
    done
    echo "Cron scripts stopped."
    ;;
  all)
    pm2 start ecosystem.config.cjs
    sleep 3
    pm2 status
    echo ""
    echo "Command Center: http://localhost:3002"
    echo ""
    echo "All cron scripts also running."
    ;;
  status)
    pm2 status
    echo ""
    # Check dev server health
    code=$(curl -s http://localhost:3002 -o /dev/null -w '%{http_code}' 2>/dev/null || echo 'offline')
    echo "Command Center: $code (http://localhost:3002)"
    echo ""
    # Summary counts
    total=$(pm2 jlist 2>/dev/null | python3 -c "import json,sys; data=json.load(sys.stdin); print(len(data))" 2>/dev/null || echo 0)
    online=$(pm2 jlist 2>/dev/null | python3 -c "import json,sys; data=json.load(sys.stdin); print(sum(1 for p in data if p['pm2_env']['status']=='online'))" 2>/dev/null || echo 0)
    errored=$(pm2 jlist 2>/dev/null | python3 -c "import json,sys; data=json.load(sys.stdin); print(sum(1 for p in data if p['pm2_env']['status']=='errored'))" 2>/dev/null || echo 0)
    echo "Processes: $online online, $errored errored, $total total"
    ;;
  logs)
    if [ -n "$2" ]; then
      pm2 logs "$2" --lines 50
    else
      pm2 logs --lines 50
    fi
    ;;
  *)
    echo "Usage: ./dev [command]"
    echo ""
    echo "  Servers:"
    echo "    start   - Start Command Center (port 3002)"
    echo "    stop    - Stop Command Center"
    echo "    restart - Restart Command Center"
    echo ""
    echo "  Scheduled Scripts:"
    echo "    cron      - Start all cron scripts"
    echo "    stop-cron - Stop all cron scripts"
    echo ""
    echo "  Combined:"
    echo "    all     - Start Command Center + all cron scripts"
    echo ""
    echo "  Info:"
    echo "    status  - Show process status + health"
    echo "    logs    - Tail logs (optional: ./dev logs <name>)"
    ;;
esac
