{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benknight/Code/act-global-infrastructure/.codex/hooks/session_start_act_context.py",
            "timeout_sec": 5,
            "status_message": "Loading ACT workspace guardrails"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
